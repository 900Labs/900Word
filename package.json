{
  "name": "900word",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/desktop"
  ],
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0"
  },
  "scripts": {
    "build": "npm --workspace apps/desktop run build",
    "check": "npm --workspace apps/desktop run check",
    "lint": "npm --workspace apps/desktop run lint",
    "test": "npm --workspace apps/desktop run test",
    "tauri:dev": "npm --workspace apps/desktop run tauri:dev",
